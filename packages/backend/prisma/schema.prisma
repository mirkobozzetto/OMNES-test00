generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Student {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String   @unique
  dateOfBirth    DateTime
  grade          String
  enrollmentDate DateTime
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
